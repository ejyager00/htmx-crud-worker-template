{
  "name": "htmx-crud-worker-template",
  "description": "Reusable Cloudflare Worker template: Hono + HTMX + D1 + KV + Nunjucks + auth",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:dev": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.4",
    "nunjucks": "^3.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.18",
    "@types/node": "^25.3.3",
    "@types/nunjucks": "^3.2.6",
    "typescript": "5.9.3",
    "vitest": "^3.2.0",
    "wrangler": "^4.69.0"
  }
}
